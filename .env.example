# EkaScribe Configuration
# See: https://developer.eka.care/api-reference/health-ai/ekascribe/SDKs/TS-sdk#eka-care-wrapper-advanced
#
# When running as a care_fe plugin (module federation), Eka CORS checks the
# care_fe page origin (e.g. http://localhost:4000), NOT care_eka_scribe_fe :10122.
# Env vars are baked in at plugin build time — rebuild after changing this file.

# Long-lived token from console.dev.eka.care (DEV) or console.eka.care (PROD)
# Token and env MUST match — prod token + DEV env causes "CORS" / Forbidden errors.
REACT_EKA_ACCESS_TOKEN=

# DEV  → api.dev.eka.care  + token from console.dev.eka.care
# PROD → api.eka.care      + token from console.eka.care (use with ngrok HTTPS)
REACT_EKA_ENV=PROD
